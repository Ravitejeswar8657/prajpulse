# Optional — enables the "deep analysis" button. Leave unset to run lexicon-only.
ANTHROPIC_API_KEY=
# How often the background scheduler re-pulls news (minutes)
REFRESH_MINUTES=30
# Protect POST /api/refresh in production
REFRESH_TOKEN=
# Lock CORS to your frontend origin in prod, e.g. https://praja-pulse.netlify.app
ALLOW_ORIGINS=*
